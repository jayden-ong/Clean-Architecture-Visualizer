{
  "name": "clean-architecture-visualizer",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('package.json', 'dist/package.json')\" && npm run build_frontend",
    "build_frontend": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "cross-env NODE_ENV=production node ./dist/src/app/index.js",
    "dev": "npm run build && cross-env NODE_ENV=development node ./dist/src/app/index.js start",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' jest --no-cache"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/paulgries/Clean-Architecture-Visualizer/issues"
  },
  "bin": {
    "cave": "dist/src/app/index.js"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5"
  },
  "type": "module",
  "files": [
    "dist/",
    "frontend/dist/"
  ]
}
